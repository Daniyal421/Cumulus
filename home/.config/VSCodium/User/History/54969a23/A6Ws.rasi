/**
 *
 * Cumulus Wi-Fi
 *
 **/

@import "menu.rasi"

configuration {
    show-icons: false;
}

/***** Window *****/

window {
    width: 470px;

    x-offset: 12px;
    y-offset: 40px;
}

/***** Search *****/

entry {
    placeholder: "Search Wi-Fi...";
}

/***** List *****/

listview {
    lines: 10;
}

/***** Selected Network *****/

element selected.normal {
    background-color: @background-alt;
    text-color: @selected;
}